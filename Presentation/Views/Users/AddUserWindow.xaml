<Window x:Class="CONEX_APP.Presentation.Views.Users.AddUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Añadir Nuevo Usuario" Height="500" Width="400" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,0,0,10">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Nombre:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Primer Apellido:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Surname, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Segundo Apellido:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding SecondSurname, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="DNI / NIF:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding IdCard, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Teléfono:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Correo Electrónico:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Dirección:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Text="Localidad:" Margin="0,0,0,5"/>
                <TextBox Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Padding="5"/>

                <CheckBox Content="Es Socio" IsChecked="{Binding IsPartner}" Margin="0,0,0,10"/>
                <CheckBox Content="Es Tutor" IsChecked="{Binding IsTutor}" Margin="0,0,0,20"/>

                <TextBlock Text="Añadir a Clase/Actividad:" Margin="0,0,0,5"/>
                <ComboBox ItemsSource="{Binding AvailableActivities}" SelectedItem="{Binding SelectedActivityToAdd, UpdateSourceTrigger=PropertyChanged}" DisplayMemberPath="Name" Margin="0,0,0,5" Padding="5"/>
                
                <TextBlock Text="Clases Seleccionadas:" Margin="0,0,0,5" FontSize="11" Foreground="Gray"/>
                <ListBox ItemsSource="{Binding SelectedActivities}" DisplayMemberPath="Name" Height="60" Margin="0,0,0,15"/>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
            <Button Content="Cancelar" Command="{Binding CancelCommand}" Width="80" Margin="0,0,10,0" Padding="5"/>
            <Button Content="Guardar" Command="{Binding SaveCommand}" Width="80" Padding="5" Background="#007ACC" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
