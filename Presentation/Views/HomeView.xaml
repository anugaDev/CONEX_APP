<UserControl x:Class="CONEX_APP.Presentation.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F5F5">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <TextBlock Text="CONEX APP" FontSize="36" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40" Foreground="#333333"/>
            
            <Button Content="Tabla de Usuarios" Command="{Binding GoToUsersCommand}" 
                    Height="50" Margin="0,0,0,15" FontSize="16" Background="#007ACC" Foreground="White" FontWeight="SemiBold"/>
                    
            <Button Content="Tabla de Clases" Command="{Binding GoToClassesCommand}" 
                    Height="50" Margin="0,0,0,15" FontSize="16" Background="#007ACC" Foreground="White" FontWeight="SemiBold"/>
                    
            <Button Content="Salir" Command="{Binding ExitCommand}" 
                    Height="50" FontSize="16" Background="#D32F2F" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
