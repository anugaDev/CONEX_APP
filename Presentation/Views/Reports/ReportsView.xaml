<UserControl x:Class="CONEX_APP.Presentation.Views.Reports.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,30">
            <Button Content="Atrás" Command="{Binding GoBackCommand}" Width="80" Padding="5" Margin="0,0,20,0"/>
            <TextBlock Text="Sección de Listados" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" Foreground="#333333"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
            <TextBlock Text="Selecciona un listado para generar el PDF:" FontSize="16" Margin="0,0,0,20" Foreground="#555555" HorizontalAlignment="Center"/>
            
            <Button Content="🖨️ Imprimir Listado de Socios" Command="{Binding PrintPartnersCommand}" 
                    Height="50" Margin="0,0,0,15" FontSize="16" Background="#FF8C00" Foreground="White" FontWeight="SemiBold"/>
                    
            <Button Content="🖨️ Imprimir Listado de Enseñantes" Command="{Binding PrintTutorsCommand}" 
                    Height="50" Margin="0,0,0,15" FontSize="16" Background="#FF8C00" Foreground="White" FontWeight="SemiBold"/>
                    
            <Button Content="🖨️ Imprimir Listado de Clases Totales" Command="{Binding PrintTotalClassesCommand}" 
                    Height="50" Margin="0,0,0,15" FontSize="16" Background="#FF8C00" Foreground="White" FontWeight="SemiBold"/>
                    
            <Button Content="🖨️ Imprimir Listado de Usuarios por Clase" Command="{Binding PrintUsersPerClassCommand}" 
                    Height="50" FontSize="16" Background="#FF8C00" Foreground="White" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
